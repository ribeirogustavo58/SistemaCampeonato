<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <VBox alignment="TOP_CENTER" layoutX="40.0" layoutY="20.0" prefHeight="560.0" prefWidth="820.0" spacing="25.0" styleClass="glass-panel">
            <padding>
                <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="760.0" spacing="20.0">
                    <children>
                        <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true">
                            <image>
                                <Image url="@../img/cs2logo.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="label-master-title" text="TABELA DE CLASSIFICAÇÃO" />
                    </children>
                </HBox>

                <TableView prefHeight="390.0" prefWidth="760.0">
                    <columns>
                        <TableColumn prefWidth="80.0" text="Pos" />
                        <TableColumn prefWidth="260.0" text="Equipe" />
                        <TableColumn prefWidth="110.0" text="Pontos" />
                        <TableColumn prefWidth="110.0" text="Vitórias" />
                        <TableColumn prefWidth="110.0" text="Derrotas" />
                        <TableColumn prefWidth="85.0" text="Saldo RD" />
                    </columns>
                </TableView>

                <HBox alignment="BOTTOM_LEFT" prefHeight="40.0" prefWidth="760.0">
                    <children>
                        <Button styleClass="btn-secondary-ghost" text="VOLTAR" prefWidth="120.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>