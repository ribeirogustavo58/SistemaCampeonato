<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <VBox alignment="CENTER" layoutX="50.0" layoutY="30.0" prefHeight="540.0" prefWidth="800.0" spacing="40.0">
            <children>

                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <ImageView fitHeight="140.0" fitWidth="140.0" preserveRatio="true">
                            <image>
                                <Image url="@../img/cs2logo.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="label-master-title" text="SISTEMA DE CAMPEONATO CS2" />
                        <Label style="-fx-text-fill: #718096; -fx-font-size: 16px; -fx-font-weight: bold; -fx-letter-spacing: 2px;" text="PAINEL DE CONTROLE PRINCIPAL" />
                    </children>
                </VBox>

                <GridPane hgap="25.0" prefHeight="220.0" prefWidth="800.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="100.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>

                        <VBox alignment="CENTER" spacing="15.0" styleClass="glass-panel">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label style="-fx-text-fill: #4f46e5; -fx-font-size: 16px; -fx-font-weight: bold;" text="EQUIPES" />
                                <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-text-alignment: center;" text="Inscrever novos times e gerenciar capitães." wrapText="true" />
                                <Button styleClass="btn-primary-magnetic" text="GERENCIAR" prefWidth="180.0" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="15.0" styleClass="glass-panel" GridPane.columnIndex="1">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label style="-fx-text-fill: #4f46e5; -fx-font-size: 16px; -fx-font-weight: bold;" text="CONFRONTOS" />
                                <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-text-alignment: center;" text="Lançar resultados e acompanhar scores." wrapText="true" />
                                <Button styleClass="btn-primary-magnetic" text="PARTIDAS" prefWidth="180.0" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" spacing="15.0" styleClass="glass-panel" GridPane.columnIndex="2">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label style="-fx-text-fill: #4f46e5; -fx-font-size: 16px; -fx-font-weight: bold;" text="CLASSIFICAÇÃO" />
                                <Label style="-fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-text-alignment: center;" text="Visualizar a tabela de pontos e saldo de rounds." wrapText="true" />
                                <Button styleClass="btn-primary-magnetic" text="LEADERBOARD" prefWidth="180.0" />
                            </children>
                        </VBox>

                    </children>
                </GridPane>

                <HBox alignment="CENTER" prefHeight="30.0" prefWidth="800.0">
                    <children>
                        <Label style="-fx-text-fill: #4A5568; -fx-font-size: 11px;" text="V.1.0.0 — DESIGN HUB PREMIUM" />
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>