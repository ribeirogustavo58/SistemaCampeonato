<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <VBox alignment="CENTER" layoutX="150.0" layoutY="30.0" prefHeight="540.0" prefWidth="600.0" spacing="25.0" styleClass="glass-panel">
            <padding>
                <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
            </padding>
            <children>
                <ImageView fitHeight="130.0" fitWidth="130.0" preserveRatio="true">
                    <image>
                        <Image url="@../img/cs2logo.png" />
                    </image>
                </ImageView>

                <Label styleClass="label-master-title" text="CADASTRO DE EQUIPE" />

                <GridPane hgap="20.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="70.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="70.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <VBox prefWidth="240.0">
                            <children>
                                <Label styleClass="label-field" text="Nome do Time" />
                                <TextField promptText="Ex: Fúria" />
                            </children>
                        </VBox>
                        <VBox prefWidth="240.0" GridPane.columnIndex="1">
                            <children>
                                <Label styleClass="label-field" text="Capitão (IGL)" />
                                <TextField promptText="Nome do jogador" />
                            </children>
                        </VBox>
                        <VBox prefWidth="500.0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                        </VBox>
                    </children>
                </GridPane>

                <HBox alignment="CENTER" prefHeight="70.0" prefWidth="500.0" spacing="30.0">
                    <children>
                        <Button styleClass="btn-secondary-ghost" text="VOLTAR" prefWidth="220.0" />
                        <Button styleClass="btn-primary-magnetic" text="CADASTRAR" prefWidth="220.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>