<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <VBox alignment="TOP_CENTER" layoutX="40.0" layoutY="20.0" prefHeight="560.0" prefWidth="820.0" spacing="25.0" styleClass="glass-panel">
            <padding>
                <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="760.0" spacing="20.0">
                    <children>
                        <ImageView fitHeight="60.0" fitWidth="60.0" preserveRatio="true">
                            <image>
                                <Image url="@../img/cs2logo.png" />
                            </image>
                        </ImageView>
                        <Label styleClass="label-master-title" text="GERENCIAR PARTIDAS" />
                    </children>
                </HBox>

                <HBox alignment="CENTER" prefHeight="90.0" prefWidth="760.0" spacing="15.0" styleClass="glass-panel" style="-fx-padding: 15; -fx-background-color: rgba(18, 21, 27, 0.8);">
                    <children>
                        <ComboBox prefWidth="180.0" promptText="Time A" />
                        <TextField alignment="CENTER" prefWidth="60.0" promptText="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 10;" />
                        <Label style="-fx-text-fill: #4f46e5; -fx-font-weight: bold; -fx-font-size: 24px; -fx-effect: dropshadow(three-pass-box, rgba(79, 70, 229, 0.6), 10, 0, 0, 0);" text="VS" />
                        <TextField alignment="CENTER" prefWidth="60.0" promptText="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 10;" />
                        <ComboBox prefWidth="180.0" promptText="Time B" />
                        <Button styleClass="btn-primary-magnetic" text="LANÇAR SCORE" />
                    </children>
                </HBox>

                <TableView prefHeight="280.0" prefWidth="760.0">
                    <columns>
                        <TableColumn prefWidth="90.0" text="ID" />
                        <TableColumn prefWidth="210.0" text="Time A" />
                        <TableColumn prefWidth="130.0" text="Resultado" />
                        <TableColumn prefWidth="210.0" text="Time B" />
                        <TableColumn prefWidth="115.0" text="Status" />
                    </columns>
                </TableView>

                <HBox alignment="BOTTOM_LEFT" prefHeight="40.0" prefWidth="760.0">
                    <children>
                        <Button styleClass="btn-secondary-ghost" text="VOLTAR" prefWidth="120.0" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>